{
  "expo": {
    "name": "Cosmic",
    "slug": "cosmic",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cosmic",
    "icon": "./assets/splash-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.cosmic"
    },
    "android": {
      "package": "com.yourname.cosmic"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
